ENABLE_ACHIEVEMENTS=true
ENABLE_DAILY_BONUS=true
ENABLE_LEADERBOARD=true
ENABLE_TASKS=true

# ==================== BACKUP CONFIGURATION ====================

# Automatic backup settings
BACKUP_ENABLED=false
BACKUP_INTERVAL=86400  # 24 hours in seconds
BACKUP_PATH=./backups

